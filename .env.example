# =============================================================
# Arab Annotators — Environment Variables
# =============================================================
# STEP 1: Copy this file → .env.local
# STEP 2: Fill in your Supabase values (from supabase.com)
# STEP 3: For Vercel: add all 4 vars in Project Settings → Environment Variables
#
# TO DIAGNOSE: after deploy, visit  /api/health  — it shows exactly what's wrong
# =============================================================

# ─── Supabase (required) ──────────────────────────────────────────────────────
# From: supabase.com → Your Project → Settings → API

# The project URL (format: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# The anon/public key (safe to expose — used client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# The service_role key (SECRET — only used server-side in API routes)
# NEVER prefix with NEXT_PUBLIC_ — this must stay server-only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Admin account (required for seed) ────────────────────────────────────────
SUPER_ADMIN_EMAIL=your-email@domain.com
SUPER_ADMIN_PASSWORD=YourStrongPassword2024!

# ─── Seed protection (required) ───────────────────────────────────────────────
# Any random string — used to protect the /api/users/seed endpoint
SETUP_SECRET_KEY=change-this-to-something-random-123

# ─── App URL (optional) ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
